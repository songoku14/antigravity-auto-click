{
  "name": "antigravity-auto-click",
  "version": "1.0.0",
  "description": "Auto-click Retry and Accept buttons in Antigravity (Auto-Retry & Auto-Accept)",
  "main": "src/extension/extension.js",
  "publisher": "antigravity",
  "displayName": "Antigravity Auto-Click",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:antigravity-auto-click.openControlCenter",
    "onCommand:antigravity-auto-click.startDaemon",
    "onCommand:antigravity-auto-click.stopDaemon",
    "onCommand:antigravity-auto-click.reloadDaemon",
    "onCommand:antigravity-auto-click.toggleAutoRetry",
    "onCommand:antigravity-auto-click.toggleAutoAccept",
    "onCommand:antigravity-auto-click.openConfig",
    "onCommand:antigravity-auto-click.openLogs",
    "onCommand:antigravity-auto-click.showActivitySummary"
  ],
  "contributes": {
    "commands": [
      {
        "command": "antigravity-auto-click.openControlCenter",
        "title": "Antigravity: Open Control Center"
      },
      {
        "command": "antigravity-auto-click.startDaemon",
        "title": "Antigravity: Start Auto-Click"
      },
      {
        "command": "antigravity-auto-click.stopDaemon",
        "title": "Antigravity: Stop Auto-Click"
      },
      {
        "command": "antigravity-auto-click.reloadDaemon",
        "title": "Antigravity: Reload Auto-Click"
      },
      {
        "command": "antigravity-auto-click.toggleAutoRetry",
        "title": "Antigravity: Toggle Auto Retry"
      },
      {
        "command": "antigravity-auto-click.toggleAutoAccept",
        "title": "Antigravity: Toggle Auto Accept"
      },
      {
        "command": "antigravity-auto-click.openConfig",
        "title": "Antigravity: Open Config"
      },
      {
        "command": "antigravity-auto-click.openLogs",
        "title": "Antigravity: Open Logs"
      },
      {
        "command": "antigravity-auto-click.showActivitySummary",
        "title": "Antigravity: Show Activity Summary"
      }
    ],
    "configuration": {
      "title": "Antigravity Auto-Click Extension",
      "properties": {
        "antigravityAutoClick.extension.autoStartDaemon": {
          "type": "boolean",
          "default": true,
          "description": "Tự động start daemon khi extension activate."
        },
        "antigravityAutoClick.extension.showConfigWarningsOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Ghi cảnh báo migration/config vào Output Channel khi extension khởi động."
        }
      }
    }
  },
  "scripts": {
    "start": "node src/core/auto-retry.js",
    "start:debug": "DEBUG=1 node src/core/auto-retry.js",
    "stop": "bash scripts/core/stop.sh",
    "install-agent": "bash scripts/install.sh",
    "uninstall-agent": "bash scripts/uninstall.sh",
    "menu": "bash scripts/menu.sh",
    "test": "node scripts/tests/regression.js"
  },
  "dependencies": {
    "jsdom": "^29.1.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "vscode": "^1.80.0"
  }
}
