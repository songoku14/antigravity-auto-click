{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Antigravity Auto-Click Configuration",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "debug": {
      "type": "boolean",
      "description": "Bật log chi tiết cho daemon và extension.",
      "default": true
    },
    "logging": {
      "type": "object",
      "description": "Cấu hình ghi log hệ thống và hoạt động.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Bật/tắt ghi log hệ thống (daemon.log).",
          "default": true
        },
        "activityLog": {
          "type": "boolean",
          "description": "Bật/tắt ghi lại thống kê hoạt động (activity-log.json).",
          "default": true
        }
      }
    },
    "autoRetry": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "dialogContainerSelectors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "errorPatterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "retryButtonPatterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "retryContextPatterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "customRetryPatterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "timing": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "pollInterval": {
                  "type": "integer",
                  "minimum": 0
                },
                "clickDelay": {
                  "type": "integer",
                  "minimum": 0
                },
                "minClickInterval": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            },
            "rateLimit": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "maxRetriesPerMinute": {
                  "type": "integer",
                  "minimum": 0
                },
                "cooldownMs": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      ],
      "description": "Cấu hình Auto Retry theo schema normalize hiện tại."
    },
    "autoAccept": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "performClick": {
              "type": "boolean",
              "default": false
            },
            "blacklist": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "customAcceptPatterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "categories": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "terminal": {
                  "$ref": "#/definitions/acceptCategory"
                },
                "reviewChange": {
                  "$ref": "#/definitions/acceptCategory"
                },
                "systemReview": {
                  "$ref": "#/definitions/acceptCategory"
                },
                "review": {
                  "$ref": "#/definitions/legacyAcceptCategory"
                },
                "system": {
                  "$ref": "#/definitions/legacyAcceptCategory"
                }
              }
            }
          }
        }
      ],
      "description": "Cấu hình Auto Accept theo category chuẩn hóa."
    },
    "performClickAutoAccept": {
      "type": "boolean",
      "description": "Legacy key. Extension sẽ migrate sang autoAccept.performClick."
    },
    "blacklist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Legacy key. Extension sẽ migrate sang autoAccept.blacklist."
    },
    "customRetryPatterns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Legacy key vẫn được normalize."
    },
    "customAcceptPatterns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Legacy key vẫn được normalize."
    },
    "pollInterval": {
      "type": "integer",
      "description": "Legacy key. Extension sẽ migrate sang autoRetry.timing.pollInterval."
    },
    "clickDelay": {
      "type": "integer",
      "description": "Legacy key. Extension sẽ migrate sang autoRetry.timing.clickDelay."
    },
    "minClickInterval": {
      "type": "integer",
      "description": "Legacy key. Extension sẽ migrate sang autoRetry.timing.minClickInterval."
    },
    "maxRetriesPerMinute": {
      "type": "integer",
      "description": "Legacy key. Extension sẽ migrate sang autoRetry.rateLimit.maxRetriesPerMinute."
    },
    "cooldownMs": {
      "type": "integer",
      "description": "Legacy key. Extension sẽ migrate sang autoRetry.rateLimit.cooldownMs."
    }
  },
  "definitions": {
    "acceptCategory": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "buttons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "context": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Legacy key, được map sang context khi normalize."
        }
      }
    },
    "legacyAcceptCategory": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
