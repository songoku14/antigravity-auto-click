{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Antigravity Auto-Click Configuration",
  "type": "object",
  "properties": {
    "autoRetry": {
      "type": "boolean",
      "description": "Tự động click nút Retry khi gặp lỗi High Traffic.",
      "default": true
    },
    "performClickAutoAccept": {
      "type": "boolean",
      "description": "Thực hiện click thực tế khi Auto Accept phát hiện nút. Nếu false, chỉ ghi log và thống kê.",
      "default": false
    },
    "autoAccept": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "categories": {
              "type": "object",
              "properties": {
                "terminal": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "patterns": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "review": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "patterns": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "system": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "patterns": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ],
      "description": "Tự động chấp nhận các đề xuất từ Agent.",
      "default": false
    },
    "blacklist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Danh sách các từ khóa hoặc lệnh terminal bị cấm tự động click.",
      "default": [
        "rm ",
        "sudo ",
        "mkfs",
        "dd "
      ]
    },
    "customRetryPatterns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Các regex bổ sung để nhận diện nút Retry."
    },
    "customAcceptPatterns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Các regex bổ sung để nhận diện nút Accept."
    },
    "clickDelay": {
      "type": "integer",
      "description": "Khoảng thời gian chờ (ms) trước khi thực hiện cú click.",
      "default": 800
    },
    "minClickInterval": {
      "type": "integer",
      "description": "Khoảng cách tối thiểu (ms) giữa 2 lần click tự động.",
      "default": 2000
    },
    "pollInterval": {
      "type": "integer",
      "description": "Khoảng thời gian (ms) giữa các lần quét DOM (Passive Polling).",
      "default": 2000
    }
  }
}