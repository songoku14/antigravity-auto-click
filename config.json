{
  "debug": true,
  "autoRetry": {
    "enabled": true,
    "dialogContainerSelectors": [
      ".antigravity-mock-dialog",
      ".monaco-dialog-box",
      ".dialog-shadow",
      ".notifications-toasts",
      ".notification-toast-container",
      ".notification-list-item",
      ".notification-toast",
      ".notifications-center",
      ".jetski-error",
      ".error-overlay",
      ".test-dialog",
      ".test-accept-dialog",
      ".bg-agent-convo-background",
      ".antigravity-agent-side-panel",
      "#antigravity\\.agentSidePanelInputBox",
      "[role=\"dialog\"]",
      "[role=\"alertdialog\"]"
    ],
    "errorPatterns": [
      "/high\\s*traffic/i",
      "/server\\s*(is\\s*)?busy/i",
      "/too\\s*many\\s*requests/i",
      "/rate\\s*limit(ed)?/i",
      "/overloaded/i",
      "/temporarily\\s*unavailable/i",
      "/service\\s*unavailable/i",
      "/request\\s*failed/i",
      "/something\\s*went\\s*wrong/i",
      "/agent\\s*terminated/i",
      "/try\\s*again/i"
    ],
    "retryButtonPatterns": [
      "/^retry$/i"
    ],
    "retryContextPatterns": [
      "/high\\s*traffic/i",
      "/server\\s*(is\\s*)?busy/i",
      "/too\\s*many\\s*requests/i",
      "/rate\\s*limit(ed)?/i",
      "/overloaded/i",
      "/unavailable/i",
      "/request\\s*failed/i",
      "/something\\s*went\\s*wrong/i",
      "/agent\\s*terminated/i",
      "/try\\s*again/i",
      "/connection\\s*lost/i"
    ],
    "customRetryPatterns": [],
    "timing": {
      "pollInterval": 2000,
      "clickDelay": 1000,
      "minClickInterval": 2000
    },
    "rateLimit": {
      "maxRetriesPerMinute": 15,
      "cooldownMs": 60000
    }
  },
  "autoAccept": {
    "enabled": true,
    "performClick": true,
    "blacklist": [
      "rm ",
      "sudo ",
      "force ",
      "push ",
      "delete ",
      "terminate ",
      "pkill ",
      "kill ",
      "mkfs",
      "format "
    ],
    "customAcceptPatterns": [],
    "categories": {
      "terminal": {
        "enabled": true,
        "buttons": [
          "/^run\\s*\\(?⌥enter\\)?$/i"
        ],
        "context": [
          "/reject/i",
          "/run/i"
        ]
      },
      "reviewChange": {
        "enabled": true,
        "buttons": [
          "/^accept$/i",
          "/^accept\\s*all$/i"
        ],
        "context": [
          "/review\\s*the\\s*changes/i",
          "/reject\\s*all/i",
          "/^reject$/i"
        ]
      },
      "systemReview": {
        "enabled": false,
        "buttons": [
          "/^proceed$/i"
        ],
        "context": [
          "/proceed\\s*with\\s*changes/i"
        ]
      }
    }
  }
}
