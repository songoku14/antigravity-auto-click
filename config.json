{
  "blacklist": [
    "rm ",
    "sudo ",
    "force ",
    "push ",
    "delete ",
    "terminate ",
    "pkill ",
    "kill ",
    "mkfs",
    "format "
  ],
  "performClickAutoAccept": false,
  "autoAccept": {
    "enabled": false,
    "categories": {
      "terminal": {
        "enabled": true,
        "patterns": [
          "allow\\s*the\\s*following\\s*command",
          "run\\s*this\\s*command",
          "execute\\s*the\\s*following"
        ]
      },
      "review": {
        "enabled": true,
        "patterns": [
          "review\\s*the\\s*changes",
          "agent\\s*prompt",
          "approve\\s*request"
        ]
      },
      "system": {
        "enabled": true,
        "patterns": [
          "security\\s*confirmation",
          "allow\\s*this\\s*action"
        ]
      }
    }
  },
  "autoRetry": true,
  "debug": false,
  "clickDelay": 1000,
  "minClickInterval": 2000,
  "pollInterval": 2000
}
